{
  "name": "3tile",
  "version": "0.1.0",
  "description": "3Tile - Electron + WebGPU 3D tile modeling scaffold",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm:dev:electron\"",
    "dev:electron": "wait-on http-get://localhost:5173 --timeout 30000 && tsc -p tsconfig.main.json && electron .",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "npm run build && electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "keywords": [
    "electron",
    "webgpu",
    "3d",
    "tilemap"
  ],
  "author": "cjens00",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@webgpu/types": "^0.1.69",
    "concurrently": "^9.2.1",
    "electron": "^37.5.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "wait-on": "^8.0.5"
  }
}
